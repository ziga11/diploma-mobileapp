# --- Top Priority (The "Shit" you wanted gone) ---
node_modules/
.dart_tool/
build/
.history/
.DS_Store

# --- Flutter / Dart ---
.packages
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
# If you use fvm
.fvm/

# --- Windows (Flutter specific) ---
windows/flutter/ephemeral/
windows/flutter/generated_plugin_registrant.h
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugins.cmake
/windows/runner/*.exe
/windows/runner/*.dll
/windows/runner/*.pdb

# --- Android ---
.gradle/
local.properties
/android/app/debug
/android/app/profile
/android/app/release

# --- iOS/macOS ---
*.xcworkspace
*.xcscheme
/ios/Flutter/.last_build_id
/ios/Pods/
DerivedData/

# --- IDEs / Editors ---
.idea/
.vscode/
*.iml
*.swp
*.un~

# --- Secrets ---
.env
ios/Runner/GoogleService-Info.plist
android/app/google-services.json
